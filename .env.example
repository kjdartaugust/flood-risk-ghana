# ─── Backend ───────────────────────────────────────────────────────────────
ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Postgres / PostGIS (Supabase connection string, or local compose default)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgis:5432/floodwatch
# Sync URL used by Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@postgis:5432/floodwatch

# Redis (cache + rate limiting)
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_PER_MINUTE=120

# Supabase Auth (JWT verification)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# H3 scoring resolution (7 ≈ 5 km², 8 ≈ 0.7 km², 9 ≈ 0.1 km²)
H3_RESOLUTION=8

# ─── ETL / data sources ──────────────────────────────────────────────────────
# NASA Earthdata (GPM/IMERG) — https://urs.earthdata.nasa.gov/
EARTHDATA_TOKEN=
# Open-Meteo needs no key; used as forecast fallback
OPENMETEO_BASE=https://api.open-meteo.com/v1
GPM_IMERG_BASE=https://gpm1.gesdisc.eosdis.nasa.gov
RAINFALL_REFRESH_CRON=*/30 * * * *

# ─── ML ──────────────────────────────────────────────────────────────────────
MODEL_PATH=app/ml/artifacts/flood_model.pkl
MODEL_KIND=logistic          # logistic | lightgbm

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAP_STYLE=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAPBOX_TOKEN=            # optional, if using Mapbox styles
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
